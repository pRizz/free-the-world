{
  "schemaVersion": 1,
  "defaultProviderOrder": ["claude", "codex"],
  "providers": {
    "codex": {
      "command": "codex",
      "args": ["exec", "-s", "read-only", "-C", "{{rootDir}}", "-o", "{{lastMessageFile}}", "-"],
      "timeoutMs": 600000
    },
    "claude": {
      "command": "claude",
      "args": [
        "-p",
        "--disable-slash-commands",
        "--setting-sources",
        "project,local",
        "--permission-mode",
        "dontAsk",
        "--allowedTools",
        "Read,Grep,Glob,WebSearch,WebFetch",
        "--output-format",
        "json",
        "--debug-file",
        "{{debugFile}}"
      ],
      "timeoutMs": 600000
    }
  }
}
