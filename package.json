{
  "name": "free-the-world",
  "type": "module",
  "scripts": {
    "dev": "bun run content:compile && vite dev",
    "build": "bun run content:compile && vite build && bun run scripts/export-static.ts",
    "start": "vite start",
    "preview": "vite preview",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "typecheck": "bun run content:compile && tsc --noEmit",
    "test": "bun test src tests/unit",
    "content:validate": "bun run scripts/validate-content.ts",
    "content:compile": "bun run scripts/compile-content.ts",
    "migrate:content": "bun run scripts/migrate-content.ts",
    "company:queue": "bun run scripts/company-queue.ts",
    "company:init": "bun run scripts/company-init.ts",
    "sync:company": "bun run scripts/sync-company.ts",
    "sync:all": "bun run scripts/sync-all.ts",
    "loop": "bun run scripts/ralph-loop.ts"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "2.0.0-alpha.2",
    "@solidjs/vite-plugin-nitro-2": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-solid": "^0.577.0",
    "solid-js": "^1.9.5",
    "tailwind-merge": "^3.5.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.7",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
